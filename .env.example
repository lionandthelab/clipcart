# OAuth 공개 콜백 (자체 도메인). 설정하면 Meta/Pinterest/TikTok 인증이 모두
# 이 URL 로 리다이렉트되고, 페이지에 표시된 code 를 터미널에 붙여넣는 방식으로 동작.
# 미설정 시 Meta/Pinterest 는 localhost loopback 자동 캐치(개발모드)로 폴백.
# 각 플랫폼 개발자 콘솔의 Redirect URI 에 아래와 '똑같이'(끝 슬래시 포함) 등록할 것.
CLIPCART_OAUTH_REDIRECT=

# Instagram API with Instagram Login (2024+). 구 Facebook Login 방식(META_*,
# instagram_basic/instagram_content_publish 스코프)은 2025-01-27 폐기됨.
# Instagram 전용 앱 자격증명 사용 — App Dashboard > Instagram >
# API setup with Instagram business login > Business login settings 의 App ID/Secret.
# ACCESS_TOKEN/BUSINESS_ACCOUNT_ID 는 `clipcart auth instagram` 이 자동 저장.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# IG Reels 영상 호스팅 — S3 호환(Cloudflare R2 권장). IG API 는 공개 video_url 을
# 요구하므로 렌더된 mp4 를 여기 올려 직접 URL 을 만든다. 미설정이면 publish 시
# --video-url 로 직접 지정해야 함. PUBLIC_BASE 는 커스텀 도메인(media.acts.run) 또는 r2.dev.
CLIPCART_S3_ACCESS_KEY=
CLIPCART_S3_SECRET_KEY=
CLIPCART_S3_BUCKET=
CLIPCART_S3_ENDPOINT=
CLIPCART_S3_PUBLIC_BASE=

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
# SELF_ONLY | MUTUAL_FOLLOW_FRIENDS | PUBLIC_TO_EVERYONE (앱 심사·creator_query 후 설정)
TIKTOK_PRIVACY_LEVEL=SELF_ONLY

# Pinterest API v5 (Standard access 필요 — POST /pins)
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TOKEN=
PINTEREST_REFRESH_TOKEN=
PINTEREST_BOARD_ID=
PINTEREST_COVER_IMAGE_URL=

# Affiliate & disclosure
AFFILIATE_DEFAULT_DISCLOSURE=이 콘텐츠에는 affiliate 링크가 포함되어 있으며, 구매 시 일정 수수료를 받을 수 있습니다.
LINK_IN_BIO_URL=

# Project paths (optional overrides)
CLIPCART_DATA_DIR=./data
CLIPCART_INBOX_DIR=./inbox/videos
